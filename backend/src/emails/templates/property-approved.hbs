<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <title>Your Property is Live - CommercialUK</title>
    <!--[if mso]>
    <noscript>
        <xml>
            <o:OfficeDocumentSettings>
                <o:PixelsPerInch>96</o:PixelsPerInch>
            </o:OfficeDocumentSettings>
        </xml>
    </noscript>
    <![endif]-->
    <style type="text/css">
        /* Reset styles */
        body, table, td, p, a, li, blockquote {
            -webkit-text-size-adjust: 100%;
            -ms-text-size-adjust: 100%;
        }
        table, td {
            mso-table-lspace: 0pt;
            mso-table-rspace: 0pt;
        }
        img {
            -ms-interpolation-mode: bicubic;
            border: 0;
            height: auto;
            line-height: 100%;
            outline: none;
            text-decoration: none;
        }
        table {
            border-collapse: collapse !important;
        }
        body {
            margin: 0 !important;
            padding: 0 !important;
            width: 100% !important;
            height: 100% !important;
        }
        
        /* Base styles */
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #f8fafc;
            line-height: 1.6;
        }
        
        /* Link styles */
        a {
            color: #b8960a;
            text-decoration: none;
        }
        
        /* Button styles */
        .cta-button {
            display: inline-block;
            padding: 16px 40px;
            background: linear-gradient(135deg, #f2c514 0%, #d4a90a 100%);
            background-color: #f2c514;
            color: #1a1a1a !important;
            text-decoration: none;
            font-size: 16px;
            font-weight: 600;
            border-radius: 8px;
            mso-padding-alt: 0;
        }
        
        /* Responsive styles */
        @media only screen and (max-width: 620px) {
            .wrapper {
                width: 100% !important;
                max-width: 100% !important;
            }
            .container {
                width: 100% !important;
                max-width: 100% !important;
            }
            .content-padding {
                padding: 25px 15px !important;
            }
            .header-padding {
                padding: 30px 15px !important;
            }
            .logo-text {
                font-size: 24px !important;
            }
            .header-text {
                font-size: 18px !important;
            }
            .success-icon-cell {
                width: 60px !important;
                height: 60px !important;
            }
            .success-icon-text {
                font-size: 30px !important;
            }
            .greeting {
                font-size: 16px !important;
            }
            .main-message {
                font-size: 14px !important;
            }
            .property-card {
                padding: 20px 15px !important;
            }
            .property-card-title {
                font-size: 18px !important;
            }
            .property-card-description {
                font-size: 13px !important;
            }
            .property-detail-label {
                font-size: 12px !important;
            }
            .property-detail-value {
                font-size: 13px !important;
            }
            .cta-button {
                padding: 14px 30px !important;
                font-size: 14px !important;
            }
            .link-fallback {
                padding: 15px !important;
            }
            .link-fallback-url {
                font-size: 11px !important;
            }
            .support-section {
                padding: 20px 15px !important;
            }
            .support-text {
                font-size: 13px !important;
            }
            .footer-padding {
                padding: 25px 15px !important;
            }
            .footer-logo {
                font-size: 18px !important;
            }
            .social-link {
                width: 36px !important;
                height: 36px !important;
                line-height: 36px !important;
                font-size: 12px !important;
            }
            .footer-link {
                font-size: 12px !important;
                display: block !important;
                margin: 5px 0 !important;
            }
            .copyright {
                font-size: 11px !important;
            }
            .disclaimer {
                font-size: 10px !important;
            }
        }
        
        @media only screen and (max-width: 480px) {
            .header-padding {
                padding: 25px 10px !important;
            }
            .content-padding {
                padding: 20px 12px !important;
            }
            .logo-text {
                font-size: 22px !important;
            }
            .header-text {
                font-size: 16px !important;
            }
            .property-card {
                padding: 15px 12px !important;
            }
            .cta-button {
                padding: 12px 24px !important;
                font-size: 13px !important;
                width: 100% !important;
                box-sizing: border-box !important;
            }
        }
    </style>
</head>
<body style="margin: 0; padding: 0; background-color: #f8fafc;">
    <!-- Wrapper Table -->
    <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="background-color: #f8fafc;">
        <tr>
            <td align="center" style="padding: 20px 10px;">
                <!-- Main Container -->
                <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="600" class="container" style="max-width: 600px; width: 100%; background-color: #ffffff; border-radius: 8px; overflow: hidden; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);">
                    
                    <!-- Header -->
                    <tr>
                        <td class="header-padding" style="background: linear-gradient(135deg, #1a1a1a 0%, #2d2d2d 100%); background-color: #1a1a1a; color: white; text-align: center; padding: 40px 20px;">
                            <!-- Success Icon -->
                            <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%">
                                <tr>
                                    <td align="center" style="padding-bottom: 15px;">
                                        <table role="presentation" cellpadding="0" cellspacing="0" border="0">
                                            <tr>
                                                <td class="success-icon-cell" align="center" valign="middle" width="80" height="80" style="width: 80px; height: 80px; background-color: rgba(34, 197, 94, 0.2); border-radius: 50%; border: 2px solid #22c55e;">
                                                    <span class="success-icon-text" style="font-size: 40px; line-height: 1;">✅</span>
                                                </td>
                                            </tr>
                                        </table>
                                    </td>
                                </tr>
                                <tr>
                                    <td align="center">
                                        <h1 class="logo-text" style="margin: 0 0 10px 0; font-size: 32px; font-weight: bold; color: #f2c514;">CommercialUK</h1>
                                    </td>
                                </tr>
                                <tr>
                                    <td align="center">
                                        <p class="header-text" style="margin: 0; font-size: 24px; font-weight: 300; color: #ffffff;">Your Property is Live!</p>
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>
                    
                    <!-- Content -->
                    <tr>
                        <td class="content-padding" style="padding: 40px 30px;">
                            <!-- Greeting -->
                            <p class="greeting" style="font-size: 18px; color: #1f2937; margin: 0 0 20px 0;">
                                Dear {{firstName}}{{#if lastName}} {{lastName}}{{/if}},
                            </p>
                            
                            <!-- Main Message -->
                            <p class="main-message" style="font-size: 16px; color: #4b5563; margin: 0 0 30px 0; line-height: 1.7;">
                                Great news! Your property listing has been reviewed and approved by our admin team. Your property is now live and visible to potential buyers and tenants on CommercialUK.
                            </p>
                            
                            <!-- Property Card -->
                            <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%">
                                <tr>
                                    <td class="property-card" style="background: linear-gradient(135deg, #f0fdf4 0%, #dcfce7 100%); background-color: #f0fdf4; border: 1px solid #22c55e; border-radius: 12px; padding: 30px;">
                                        <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%">
                                            <tr>
                                                <td align="center" style="padding-bottom: 20px;">
                                                    <span style="font-size: 48px; line-height: 1;">🏢</span>
                                                </td>
                                            </tr>
                                            <tr>
                                                <td align="center">
                                                    <h2 class="property-card-title" style="margin: 0 0 10px 0; font-size: 20px; font-weight: 600; color: #1a1a1a;">{{propertyName}}</h2>
                                                </td>
                                            </tr>
                                            <tr>
                                                <td align="center" style="padding-bottom: 20px;">
                                                    <p class="property-card-description" style="margin: 0; font-size: 14px; color: #64748b;">
                                                        {{propertyAddress}}
                                                    </p>
                                                </td>
                                            </tr>
                                            {{#if propertyDetails}}
                                            <tr>
                                                <td style="padding-top: 20px; border-top: 1px solid #bbf7d0;">
                                                    <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%">
                                                        {{#if propertyType}}
                                                        <tr>
                                                            <td style="padding: 8px 0;">
                                                                <p class="property-detail-label" style="margin: 0; font-size: 13px; color: #64748b; font-weight: 600;">Property Type:</p>
                                                                <p class="property-detail-value" style="margin: 4px 0 0 0; font-size: 14px; color: #1f2937;">{{propertyType}}</p>
                                                            </td>
                                                        </tr>
                                                        {{/if}}
                                                        {{#if propertySize}}
                                                        <tr>
                                                            <td style="padding: 8px 0;">
                                                                <p class="property-detail-label" style="margin: 0; font-size: 13px; color: #64748b; font-weight: 600;">Size:</p>
                                                                <p class="property-detail-value" style="margin: 4px 0 0 0; font-size: 14px; color: #1f2937;">{{propertySize}}</p>
                                                            </td>
                                                        </tr>
                                                        {{/if}}
                                                    </table>
                                                </td>
                                            </tr>
                                            {{/if}}
                                            <tr>
                                                <td align="center" style="padding-top: 25px;">
                                                    <!--[if mso]>
                                                    <v:roundrect xmlns:v="urn:schemas-microsoft-com:vml" xmlns:w="urn:schemas-microsoft-com:office:word" href="{{propertyLink}}" style="height:48px;v-text-anchor:middle;width:200px;" arcsize="17%" stroke="f" fillcolor="#f2c514">
                                                        <w:anchorlock/>
                                                        <center style="color:#1a1a1a;font-family:sans-serif;font-size:16px;font-weight:bold;">View Property</center>
                                                    </v:roundrect>
                                                    <![endif]-->
                                                    <!--[if !mso]><!-->
                                                    <a href="{{propertyLink}}" class="cta-button" style="display: inline-block; padding: 16px 40px; background: linear-gradient(135deg, #f2c514 0%, #d4a90a 100%); background-color: #f2c514; color: #1a1a1a !important; text-decoration: none; font-size: 16px; font-weight: 600; border-radius: 8px;">View Property</a>
                                                    <!--<![endif]-->
                                                </td>
                                            </tr>
                                        </table>
                                    </td>
                                </tr>
                            </table>
                            
                            <!-- Link Fallback -->
                            <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="margin-top: 25px;">
                                <tr>
                                    <td class="link-fallback" style="padding: 20px; background-color: #f8fafc; border-radius: 8px;">
                                        <p style="margin: 0 0 10px 0; font-size: 13px; color: #64748b;">Or copy and paste this link into your browser:</p>
                                        <p class="link-fallback-url" style="margin: 0; font-size: 13px; word-break: break-all;">
                                            <a href="{{propertyLink}}" style="color: #b8960a; text-decoration: none;">{{propertyLink}}</a>
                                        </p>
                                    </td>
                                </tr>
                            </table>
                            
                            <!-- Next Steps Section -->
                            <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="margin-top: 30px; border-top: 1px solid #e5e7eb; padding-top: 30px;">
                                <tr>
                                    <td>
                                        <h3 style="margin: 0 0 20px 0; font-size: 16px; font-weight: 600; color: #1f2937; text-align: center;">What Happens Next?</h3>
                                    </td>
                                </tr>
                                
                                <tr>
                                    <td style="padding-bottom: 15px;">
                                        <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%">
                                            <tr>
                                                <td style="background-color: #fffbeb; border-radius: 8px; border-left: 3px solid #f2c514; padding: 15px;">
                                                    <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%">
                                                        <tr>
                                                            <td width="40" height="40" valign="top" style="width: 40px; min-width: 40px;">
                                                                <table role="presentation" cellpadding="0" cellspacing="0" border="0">
                                                                    <tr>
                                                                        <td align="center" valign="middle" width="40" height="40" style="width: 40px; height: 40px; background-color: #fef3c7; border-radius: 8px;">
                                                                            <span style="font-size: 20px; line-height: 1;">👁️</span>
                                                                        </td>
                                                                    </tr>
                                                                </table>
                                                            </td>
                                                            <td valign="top" style="padding-left: 15px;">
                                                                <p style="margin: 0 0 4px 0; font-size: 14px; font-weight: 600; color: #1f2937;">Increased Visibility</p>
                                                                <p style="margin: 0; font-size: 13px; color: #6b7280;">Your property is now visible to thousands of potential buyers and tenants searching on CommercialUK.</p>
                                                            </td>
                                                        </tr>
                                                    </table>
                                                </td>
                                            </tr>
                                        </table>
                                    </td>
                                </tr>
                                
                                <tr>
                                    <td style="padding-bottom: 15px;">
                                        <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%">
                                            <tr>
                                                <td style="background-color: #fffbeb; border-radius: 8px; border-left: 3px solid #f2c514; padding: 15px;">
                                                    <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%">
                                                        <tr>
                                                            <td width="40" height="40" valign="top" style="width: 40px; min-width: 40px;">
                                                                <table role="presentation" cellpadding="0" cellspacing="0" border="0">
                                                                    <tr>
                                                                        <td align="center" valign="middle" width="40" height="40" style="width: 40px; height: 40px; background-color: #fef3c7; border-radius: 8px;">
                                                                            <span style="font-size: 20px; line-height: 1;">📧</span>
                                                                        </td>
                                                                    </tr>
                                                                </table>
                                                            </td>
                                                            <td valign="top" style="padding-left: 15px;">
                                                                <p style="margin: 0 0 4px 0; font-size: 14px; font-weight: 600; color: #1f2937;">Receive Inquiries</p>
                                                                <p style="margin: 0; font-size: 13px; color: #6b7280;">You'll receive email notifications when potential buyers or tenants express interest in your property.</p>
                                                            </td>
                                                        </tr>
                                                    </table>
                                                </td>
                                            </tr>
                                        </table>
                                    </td>
                                </tr>
                                
                                <tr>
                                    <td>
                                        <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%">
                                            <tr>
                                                <td style="background-color: #fffbeb; border-radius: 8px; border-left: 3px solid #f2c514; padding: 15px;">
                                                    <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%">
                                                        <tr>
                                                            <td width="40" height="40" valign="top" style="width: 40px; min-width: 40px;">
                                                                <table role="presentation" cellpadding="0" cellspacing="0" border="0">
                                                                    <tr>
                                                                        <td align="center" valign="middle" width="40" height="40" style="width: 40px; height: 40px; background-color: #fef3c7; border-radius: 8px;">
                                                                            <span style="font-size: 20px; line-height: 1;">📊</span>
                                                                        </td>
                                                                    </tr>
                                                                </table>
                                                            </td>
                                                            <td valign="top" style="padding-left: 15px;">
                                                                <p style="margin: 0 0 4px 0; font-size: 14px; font-weight: 600; color: #1f2937;">Track Performance</p>
                                                                <p style="margin: 0; font-size: 13px; color: #6b7280;">Monitor views, inquiries, and engagement with your property through your dashboard.</p>
                                                            </td>
                                                        </tr>
                                                    </table>
                                                </td>
                                            </tr>
                                        </table>
                                    </td>
                                </tr>
                            </table>
                            
                            <!-- Support Section -->
                            <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="margin-top: 30px;">
                                <tr>
                                    <td class="support-section" style="padding: 25px; background-color: #fef3c7; border-radius: 8px; text-align: center; border: 1px solid #f2c514;">
                                        <p style="margin: 0 0 10px 0; font-size: 24px; line-height: 1;">💬</p>
                                        <p class="support-text" style="margin: 0; font-size: 14px; color: #1a1a1a;">
                                            Need help managing your listing? Our team is here to assist!<br>
                                            Contact us at <a href="mailto:support@commercialuk.co.uk" style="color: #b8960a; text-decoration: none; font-weight: 600;">support@commercialuk.co.uk</a>
                                        </p>
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>
                    
                    <!-- Footer -->
                    <tr>
                        <td class="footer-padding" style="background-color: #1a1a1a; color: #9ca3af; padding: 30px; text-align: center;">
                            <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%">
                                <tr>
                                    <td align="center" style="padding-bottom: 20px;">
                                        <p class="footer-logo" style="margin: 0; font-size: 20px; font-weight: bold; color: #f2c514;">CommercialUK</p>
                                    </td>
                                </tr>
                                <tr>
                                    <td align="center" style="padding-bottom: 20px;">
                                        <table role="presentation" cellpadding="0" cellspacing="0" border="0">
                                            <tr>
                                                <td style="padding: 0 5px;">
                                                    <a href="#" class="social-link" style="display: inline-block; width: 40px; height: 40px; background-color: #2d2d2d; border-radius: 50%; text-align: center; line-height: 40px; color: #f2c514; text-decoration: none; font-size: 12px;">in</a>
                                                </td>
                                                <td style="padding: 0 5px;">
                                                    <a href="#" class="social-link" style="display: inline-block; width: 40px; height: 40px; background-color: #2d2d2d; border-radius: 50%; text-align: center; line-height: 40px; color: #f2c514; text-decoration: none; font-size: 12px;">fb</a>
                                                </td>
                                                <td style="padding: 0 5px;">
                                                    <a href="#" class="social-link" style="display: inline-block; width: 40px; height: 40px; background-color: #2d2d2d; border-radius: 50%; text-align: center; line-height: 40px; color: #f2c514; text-decoration: none; font-size: 12px;">ig</a>
                                                </td>
                                                <td style="padding: 0 5px;">
                                                    <a href="#" class="social-link" style="display: inline-block; width: 40px; height: 40px; background-color: #2d2d2d; border-radius: 50%; text-align: center; line-height: 40px; color: #f2c514; text-decoration: none; font-size: 12px;">yt</a>
                                                </td>
                                            </tr>
                                        </table>
                                    </td>
                                </tr>
                                <tr>
                                    <td align="center" style="padding-bottom: 20px;">
                                        <a href="{{frontendUrl}}/privacy-policy" class="footer-link" style="color: #f2c514; text-decoration: none; margin: 0 10px; font-size: 14px;">Privacy Policy</a>
                                        <a href="{{frontendUrl}}/terms" class="footer-link" style="color: #f2c514; text-decoration: none; margin: 0 10px; font-size: 14px;">Terms of Service</a>
                                    </td>
                                </tr>
                                <tr>
                                    <td align="center">
                                        <p class="copyright" style="margin: 0 0 10px 0; font-size: 12px; color: #9ca3af;">
                                            © 2026 CommercialUK. All rights reserved.
                                        </p>
                                    </td>
                                </tr>
                                <tr>
                                    <td align="center">
                                        <p class="disclaimer" style="margin: 20px 0 0 0; font-size: 11px; line-height: 1.4; color: #9ca3af;">
                                            This email was sent to {{email}} on behalf of CommercialUK. This email is confidential and intended solely for the use of the individual or entity to whom it is addressed. If you have received this email in error, please contact us at <a href="mailto:support@commercialuk.co.uk" style="color: #f2c514; text-decoration: none;">support@commercialuk.co.uk</a>.
                                        </p>
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>
                    
                </table>
            </td>
        </tr>
    </table>
</body>
</html>
